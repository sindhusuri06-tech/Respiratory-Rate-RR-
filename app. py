import streamlit as st
import pandas as pd
import joblib

# Load trained model
model = joblib.load("models/sepsis_model.pkl")

st.set_page_config(page_title="SepsisSense AI", page_icon="🩺")

st.title("🩺 SepsisSense AI")
st.subheader("AI-Powered Sepsis Early Warning System")

st.write("Enter the patient's vital signs below.")

# User Inputs
heart_rate = st.number_input("Heart Rate (bpm)", 40, 200, 80)
temperature = st.number_input("Temperature (°C)", 30.0, 45.0, 37.0)
blood_pressure = st.number_input("Systolic Blood Pressure (mmHg)", 50, 250, 120)
resp_rate = st.number_input("Respiratory Rate (breaths/min)", 5, 50, 18)
spo2 = st.number_input("Oxygen Saturation (SpO₂ %)", 50, 100, 98)

if st.button("Predict Sepsis Risk"):

    input_data = pd.DataFrame({
        "HeartRate": [heart_rate],
        "Temperature": [temperature],
        "BloodPressure": [blood_pressure],
        "RespiratoryRate": [resp_rate],
        "SpO2": [spo2]
    })

    prediction = model.predict(input_data)[0]
    probability = model.predict_proba(input_data)[0][1] * 100

    st.subheader("Prediction Result")

    if prediction == 1:
        st.error("⚠️ High Risk of Sepsis")
    else:
        st.success("✅ Low Risk of Sepsis")

    st.write(f"**Risk Score:** {probability:.2f}%")

    st.subheader("Patient Summary")
    st.table(input_data)

st.markdown("---")
st.caption("SepsisSense AI | Vitalitics 2026 Hackathon")
